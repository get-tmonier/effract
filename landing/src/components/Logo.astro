---
interface Props {
  /** pixel size of the square mark */
  size?: number;
  /** animate the strands drawing themselves in */
  draw?: boolean;
  class?: string;
}
const { size = 36, draw = false, class: className = '' } = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<svg
  width={size}
  height={size}
  viewBox="0 0 120 120"
  fill="none"
  class={className}
  role="img"
  aria-label="effract"
  data-draw={draw ? '' : undefined}
>
  <defs>
    <linearGradient id={`v-${uid}`} x1="0" y1="0" x2="120" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="var(--violet-bright)"></stop>
      <stop offset="1" stop-color="var(--violet)"></stop>
    </linearGradient>
    <linearGradient id={`t-${uid}`} x1="0" y1="0" x2="120" y2="0" gradientUnits="userSpaceOnUse">
      <stop offset="0" stop-color="var(--teal-bright)"></stop>
      <stop offset="1" stop-color="var(--teal)"></stop>
    </linearGradient>
    <mask id={`m-${uid}`}>
      <rect width="120" height="120" fill="white"></rect>
      <circle cx="60" cy="60" r="9.5" fill="black"></circle>
    </mask>
  </defs>
  <g fill="none" stroke-width="9" stroke-linecap="round" class="weave">
    <path
      d="M12,60 C 18,44 30,44 36,60 C 42,76 54,76 60,60 C 66,44 78,44 84,60 C 90,76 102,76 108,60"
      stroke={`url(#v-${uid})`}></path>
    <path
      d="M12,60 C 18,76 30,76 36,60 C 42,44 54,44 60,60 C 66,76 78,76 84,60 C 90,44 102,44 108,60"
      stroke={`url(#t-${uid})`}
      mask={`url(#m-${uid})`}></path>
  </g>
</svg>

<style>
  [data-draw] .weave path {
    stroke-dasharray: 240;
    --len: 240;
    animation: weave-draw 1.4s var(--ease-out-expo) forwards;
  }
  [data-draw] .weave path:nth-child(2) {
    animation-delay: 0.18s;
  }
</style>
