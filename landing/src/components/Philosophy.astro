---
import CodeWindow from '#components/CodeWindow.astro';
import { emphasize } from '#lib/text';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
}
const { philosophy } = Astro.props.content;

const code = `// The logic — state, derivation, mutation — in one service.
// The shape is inferred from make; scale it up with Effect.gen + deps.
class Cart extends Context.Service<Cart>()('Cart', {
  make: Effect.sync(() => {
    const items = atom<Item[]>([])
    return {
      items,
      total: items.derive(xs => xs.reduce((n, i) => n + i.price, 0)),
      add: (item: Item) => items.update(xs => [...xs, item]),
    }
  }),
}) {
  static layer = Layer.effect(Cart, Cart.make)
}

// The component only reads and renders — no useState, no logic
const Summary = rec(function* () {
  const cart = yield* Cart
  const total = yield* cart.total       // reactive read
  return <button onClick={() => cart.add(coffee)}>add · \${total}</button>
})`;
---

<section class="relative overflow-hidden border-y border-line bg-bg-2/40">
  <div class="phil-glow" aria-hidden="true"></div>
  <div class="mx-auto max-w-6xl px-5 py-14 sm:py-20 lg:py-24">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-3 font-mono text-xs tracking-widest text-teal uppercase">{philosophy.label}</p>
      <h2 class="text-3xl font-bold tracking-tight text-balance sm:text-4xl">{philosophy.title}</h2>
      <p class="mt-5 leading-relaxed text-ink-dim text-pretty" set:html={emphasize(philosophy.body)} />
    </div>

    <div class="reveal mx-auto mt-12 max-w-3xl" style="--reveal-delay: 90ms">
      <CodeWindow code={code} title="cart.ts" />
      <p
        class="mt-4 text-center text-sm text-muted text-pretty"
        set:html={emphasize(philosophy.caption)}
      />
    </div>

    <div class="mt-14 grid grid-cols-1 gap-x-10 gap-y-10 md:grid-cols-2">
      {
        philosophy.points.map((point, i) => (
          <div class="reveal min-w-0" style={`--reveal-delay: ${(i % 2) * 90}ms`}>
            <div class="flex items-center gap-3">
              <span class="h-px w-8 bg-gradient-to-r from-violet to-teal" />
              <h3 class="font-semibold tracking-tight text-ink">{point.title}</h3>
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink-dim">{point.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .phil-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(50rem 24rem at 50% 0%, rgba(41, 211, 194, 0.07), transparent 70%);
    pointer-events: none;
  }
</style>
