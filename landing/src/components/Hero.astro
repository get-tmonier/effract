---
import FiberWeave from '#components/FiberWeave.astro';
import Logo from '#components/Logo.astro';
import { SITE, localePath } from '#lib/site';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
  locale: 'en' | 'fr';
}
const { content, locale } = Astro.props;
const { hero } = content;
---

<section class="relative overflow-hidden">
  <div class="hero-grid" aria-hidden="true"></div>
  <div class="hero-aurora" aria-hidden="true"></div>

  <div class="reveal mx-auto max-w-4xl px-5 pt-28 pb-20 text-center lg:pt-36 lg:pb-24">
    <div class="mb-6 inline-flex items-center gap-2.5">
      <Logo size={40} draw />
      <span
        class="rounded-full border border-line bg-panel/60 px-3 py-1 text-xs font-medium tracking-wide text-ink-dim uppercase"
      >
        {hero.eyebrow}
      </span>
    </div>

    <h1 class="text-4xl leading-[1.08] font-bold tracking-tight text-balance sm:text-5xl lg:text-6xl">
      {hero.titleLead}{' '}
      <span class="fiber-text-shimmer">{hero.titleGradient}</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-balance text-ink-dim">
      {hero.subtitle}
    </p>

    <!-- the centerpiece: two fibers, woven and alive -->
    <FiberWeave content={content} class="mx-auto mt-14 max-w-3xl" />

    <div class="mt-12 flex flex-wrap items-center justify-center gap-3">
      <a
        href={localePath('/docs/', locale)}
        class="group inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-violet to-teal px-5 py-3 text-sm font-semibold text-bg shadow-lg shadow-violet/20 transition-transform hover:-translate-y-0.5"
      >
        {hero.ctaPrimary}
        <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>
      <a
        href={SITE.github}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-xl border border-line bg-panel/50 px-5 py-3 text-sm font-semibold transition-colors hover:border-line-2 hover:bg-panel"
      >
        ★ {hero.ctaSecondary}
      </a>
    </div>

    <div class="mt-6 flex flex-col items-center gap-2">
      <button
        type="button"
        class="copy-install group flex max-w-full items-center gap-3 overflow-x-auto rounded-lg border border-line bg-bg-2/70 px-4 py-2.5 font-mono text-xs whitespace-nowrap transition-colors hover:border-line-2 sm:text-sm"
        data-copy="npm i @tmonier/effract"
        aria-label="Copy install command"
      >
        <span class="text-teal">$</span>
        <span class="text-ink-dim">npm i <span class="text-ink">@tmonier/effract</span></span>
        <span class="copy-icon pl-2 text-muted transition-colors group-hover:text-ink">⧉</span>
      </button>
      <p class="text-xs text-muted">{hero.installNote}</p>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    position: absolute;
    inset: -2px;
    background-image:
      linear-gradient(to right, var(--line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--line) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(60rem 40rem at 50% -10%, #000 30%, transparent 75%);
    opacity: 0.35;
    pointer-events: none;
  }
  .hero-aurora {
    position: absolute;
    top: -20rem;
    left: 50%;
    width: 70rem;
    height: 40rem;
    translate: -50% 0;
    background: radial-gradient(closest-side, rgba(124, 92, 255, 0.18), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.copy-install').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
        const icon = btn.querySelector('.copy-icon');
        if (icon) {
          const prev = icon.textContent;
          icon.textContent = '✓';
          setTimeout(() => {
            icon.textContent = prev;
          }, 1400);
        }
      } catch {
        /* clipboard unavailable */
      }
    });
  });
</script>
