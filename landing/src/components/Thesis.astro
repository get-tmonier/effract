---
import CodeWindow from '#components/CodeWindow.astro';
import { emphasize } from '#lib/text';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
}
const { thesis, callsite } = Astro.props.content;

const code = `// Counter: a React component,
// written as an Effect program
const Counter = rec(function* () {
  const stats = yield* Stats
  const [n] = yield* hook(useState(0))
  return <Row n={n} of={stats.total}/>
})

// DI checked at compile time:
createRoot(el).render(
  mount(AppLive, Counter),
)`;
---

<section id="thesis" class="relative mx-auto max-w-6xl px-5 py-14 sm:py-20 lg:py-24">
  <div class="grid grid-cols-1 gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
    <div class="reveal">
      <p class="mb-3 font-mono text-xs tracking-widest text-teal uppercase">{thesis.label}</p>
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{thesis.title}</h2>
      <p class="mt-5 leading-relaxed text-ink-dim text-pretty" set:html={emphasize(thesis.body)} />

      <ul class="mt-7 overflow-hidden rounded-2xl border border-line">
        {
          thesis.rows.map((row, i) => (
            <li
              class="grid grid-cols-1 gap-x-4 gap-y-1 px-5 py-3.5 sm:grid-cols-[minmax(0,_44%)_minmax(0,1fr)] sm:items-center"
              class:list={[i % 2 === 0 ? 'bg-panel/40' : 'bg-transparent']}
            >
              <code class="font-mono text-sm break-words text-violet-bright">{row.write}</code>
              <span class="text-sm text-ink-dim">{row.does}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="reveal" style="--reveal-delay: 120ms">
      <CodeWindow code={code} title="counter.tsx" />
      <p
        class="mt-4 text-center text-sm text-muted text-pretty"
        set:html={emphasize(callsite.caption)}
      />
    </div>
  </div>
</section>
