---
import Cta from '#components/Cta.astro';
import Everywhere from '#components/Everywhere.astro';
import Features from '#components/Features.astro';
import Footer from '#components/Footer.astro';
import Hero from '#components/Hero.astro';
import Loading from '#components/Loading.astro';
import Nav from '#components/Nav.astro';
import Philosophy from '#components/Philosophy.astro';
import Thesis from '#components/Thesis.astro';
import TypedErrors from '#components/TypedErrors.astro';
import Base from '#layouts/Base.astro';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
  locale: 'en' | 'fr';
}
const { content, locale } = Astro.props;
---

<Base title={content.meta.title} description={content.meta.description} locale={locale}>
  <Nav content={content} locale={locale} />
  <main>
    <Hero content={content} locale={locale} />
    <Thesis content={content} />
    <Everywhere content={content} />
    <Philosophy content={content} />
    <TypedErrors content={content} />
    <Loading content={content} />
    <Features content={content} />
    <Cta content={content} locale={locale} />
  </main>
  <Footer content={content} locale={locale} />
</Base>
