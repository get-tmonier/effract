---
import { emphasize } from '#lib/text';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
}
const { features } = Astro.props.content;
const last = features.items.length - 1;
const cardBase =
  'reveal group relative overflow-hidden rounded-2xl border border-line bg-panel/30 p-6 transition-all duration-300 hover:border-line-2 hover:bg-panel/60';
const badge =
  'inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-line-2 bg-bg-2 font-mono text-sm text-teal';
---

<section id="features" class="mx-auto max-w-6xl px-5 py-14 sm:py-20 lg:py-24">
  <div class="reveal mx-auto max-w-2xl text-center">
    <p class="mb-3 font-mono text-xs tracking-widest text-teal uppercase">{features.label}</p>
    <h2 class="text-3xl font-bold tracking-tight text-balance sm:text-4xl">{features.title}</h2>
  </div>

  <div class="mt-14 grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      features.items.map((item, i) => {
        const num = String(i + 1).padStart(2, '0');
        // The last card spans the full row as a horizontal "capstone", so an odd
        // count never leaves a stray card alone in the grid.
        return i === last ? (
          <article class={`${cardBase} md:col-span-2 md:flex md:items-center md:gap-8 lg:col-span-3`}>
            <div class="flex items-center gap-4 md:w-1/3 md:shrink-0">
              <div class={badge}>{num}</div>
              <h3 class="font-semibold tracking-tight">{item.title}</h3>
            </div>
            <p
              class="mt-3 text-sm leading-relaxed text-ink-dim md:mt-0 md:flex-1"
              set:html={emphasize(item.desc)}
            />
          </article>
        ) : (
          <article
            class={`${cardBase} hover:-translate-y-1`}
            style={`--reveal-delay: ${(i % 3) * 80}ms`}
          >
            <div class={`mb-4 ${badge}`}>{num}</div>
            <h3 class="font-semibold tracking-tight">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-dim" set:html={emphasize(item.desc)} />
          </article>
        );
      })
    }
  </div>
</section>
