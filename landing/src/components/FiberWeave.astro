---
/**
 * The thesis as the hero's living backdrop: a field of woven fibers — teal
 * (React) and violet (Effect) — with bright comets of light racing along them in
 * opposite directions and crossing at the weave. It sits *behind* the hero
 * content (dimmed in the centre so text stays readable), so it costs no vertical
 * space. Two glowing tags name the colours.
 */
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
}
const { weave } = Astro.props.content;

const VW = 1200;
const VH = 600;
const my = VH / 2;
const N = 6;
const amp = 124;
const periodX = 400; // 3 weave periods across the band
const k = (Math.PI * 2) / periodX;
const step = 8;

const strands = Array.from({ length: N }, (_, i) => {
  const phase = (i / N) * Math.PI * 2;
  let d = '';
  let len = 0;
  let prev: [number, number] | null = null;
  for (let x = 0; x <= VW; x += step) {
    const y = my + Math.sin(x * k + phase) * amp;
    if (prev) len += Math.hypot(x - prev[0], y - prev[1]);
    prev = [x, y];
    d += `${x === 0 ? 'M' : 'L'}${x.toFixed(1)},${y.toFixed(1)} `;
  }
  const length = Math.round(len);
  return {
    d: d.trim(),
    react: i % 2 === 0,
    length,
    gap: length - 64,
    dur: (3.0 + i * 0.4).toFixed(2),
  };
});
---

<div class="fw-bg" aria-hidden="true">
  <svg
    class="fw-svg"
    viewBox={`0 0 ${VW} ${VH}`}
    preserveAspectRatio="xMidYMid slice"
    fill="none"
    role="img"
    aria-label={weave.aria}
  >
    <defs>
      <linearGradient id="fw-teal" x1="0" y1="0" x2={VW} y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="var(--teal)"></stop>
        <stop offset="0.5" stop-color="var(--teal-bright)"></stop>
        <stop offset="1" stop-color="var(--teal)"></stop>
      </linearGradient>
      <linearGradient id="fw-violet" x1="0" y1="0" x2={VW} y2="0" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="var(--violet)"></stop>
        <stop offset="0.5" stop-color="var(--violet-bright)"></stop>
        <stop offset="1" stop-color="var(--violet)"></stop>
      </linearGradient>
      <!-- gently dim the centre so the headline stays readable; bright toward the edges -->
      <radialGradient id="fw-vig" cx="0.5" cy="0.5" r="0.66">
        <stop offset="0" stop-color="#3c3c3c"></stop>
        <stop offset="0.5" stop-color="#838383"></stop>
        <stop offset="0.9" stop-color="#fff"></stop>
      </radialGradient>
      <mask id="fw-mask">
        <rect width={VW} height={VH} fill="url(#fw-vig)"></rect>
      </mask>
    </defs>

    <g mask="url(#fw-mask)" stroke-linecap="round" fill="none">
      {/* dim base strands */}
      {
        strands.map((s) => (
          <path
            class:list={['fw-base', s.react ? 'react' : 'effect']}
            d={s.d}
            stroke={s.react ? 'url(#fw-teal)' : 'url(#fw-violet)'}
          />
        ))
      }
      {/* bright comets of light — React one way, Effect the other */}
      {
        strands.map((s) => (
          <path
            class:list={['fw-comet', s.react ? 'react' : 'effect']}
            d={s.d}
            style={`--len:${s.length};--gap:${s.gap};--dur:${s.dur}s`}
          />
        ))
      }
    </g>
  </svg>

  <span class="fw-tag teal">{weave.react}</span>
  <span class="fw-tag violet">{weave.effect}</span>
</div>

<style>
  .fw-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .fw-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .fw-base {
    stroke-width: 2.5;
    opacity: 0.42;
    filter: drop-shadow(0 0 3px currentColor);
  }
  .fw-base.react,
  .fw-comet.react {
    color: var(--teal-bright);
  }
  .fw-base.effect,
  .fw-comet.effect {
    color: var(--violet-bright);
  }

  .fw-comet {
    stroke: currentColor;
    stroke-width: 3.6;
    stroke-dasharray: 64 var(--gap);
    stroke-dashoffset: var(--len);
    filter: drop-shadow(0 0 7px currentColor) drop-shadow(0 0 15px currentColor);
    animation: fw-run var(--dur) linear infinite;
  }
  .fw-comet.effect {
    animation-direction: reverse;
  }
  @keyframes fw-run {
    from {
      stroke-dashoffset: var(--len);
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Glowing tags on the fibers — not a chart legend. */
  .fw-tag {
    position: absolute;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, currentColor 35%, transparent);
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    backdrop-filter: blur(4px);
    color: currentColor;
    box-shadow: 0 0 16px -4px currentColor;
    white-space: nowrap;
  }
  .fw-tag::before {
    content: '';
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    margin-right: 0.4rem;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 8px currentColor;
    vertical-align: middle;
  }
  .fw-tag.teal {
    color: var(--teal-bright);
    bottom: 20%;
    left: 5%;
  }
  .fw-tag.violet {
    color: var(--violet-bright);
    bottom: 8%;
    right: 5%;
  }

  @media (max-width: 640px) {
    .fw-tag {
      font-size: 0.64rem;
      padding: 0.2rem 0.5rem;
    }
    .fw-tag.teal {
      bottom: 15%;
      left: 4%;
    }
    .fw-tag.violet {
      bottom: 6%;
      right: 4%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fw-comet {
      animation: none;
      opacity: 0;
    }
    .fw-base {
      opacity: 0.45;
    }
  }
</style>
