---
import Logo from '#components/Logo.astro';
import { SITE, localePath } from '#lib/site';
import type { SiteContent } from '#i18n/types';

interface Props {
  content: SiteContent;
  locale: 'en' | 'fr';
}
const { content, locale } = Astro.props;
const { nav } = content;
const altLocale = locale === 'fr' ? 'en' : 'fr';
const altPath =
  locale === 'fr'
    ? Astro.url.pathname.replace(/^\/fr\//, '/').replace(/^\/fr$/, '/')
    : `/fr${Astro.url.pathname === '/' ? '/' : Astro.url.pathname}`;
const base = locale === 'fr' ? '/fr/' : '/';
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-colors duration-300"
  data-nav
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between gap-4 px-5">
    <a href={base} class="group flex items-center gap-2.5" aria-label="effract — home">
      <Logo size={30} class="transition-transform duration-500 group-hover:rotate-[8deg]" />
      <span class="text-lg font-semibold tracking-tight">effract</span>
    </a>

    <div class="hidden items-center gap-7 text-sm text-ink-dim md:flex">
      <a href="#thesis" class="transition-colors hover:text-ink">{nav.thesis}</a>
      <a href="#everywhere" class="transition-colors hover:text-ink">{nav.everywhere}</a>
      <a href="#features" class="transition-colors hover:text-ink">{nav.features}</a>
      <a href={localePath('/docs/', locale)} class="transition-colors hover:text-ink">
        {nav.docs}
      </a>
    </div>

    <div class="flex items-center gap-2">
      <a
        href={localePath('/docs/', locale)}
        class="px-1 text-sm font-medium text-ink-dim transition-colors hover:text-ink md:hidden"
      >
        {nav.docs}
      </a>
      <a
        href={altPath}
        class="rounded-md border border-line px-2.5 py-1 text-xs font-medium text-ink-dim uppercase transition-colors hover:border-line-2 hover:text-ink"
        aria-label={`Switch to ${altLocale}`}
      >
        {altLocale}
      </a>
      <a
        href={SITE.github}
        target="_blank"
        rel="noopener"
        class="flex items-center gap-1.5 rounded-md border border-line bg-panel/60 px-3 py-1.5 text-sm font-medium transition-colors hover:border-line-2 hover:bg-panel"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        <span class="hidden sm:inline">GitHub</span>
      </a>
    </div>
  </nav>
</header>

<script>
  const nav = document.querySelector('[data-nav]');
  if (nav) {
    const onScroll = () => {
      nav.classList.toggle('scrolled', window.scrollY > 12);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  [data-nav].scrolled {
    border-color: var(--line);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(12px);
  }
</style>
