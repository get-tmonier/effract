{
  "name": "@effract/landing",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "imports": {
    "#components/*": "./src/components/*",
    "#layouts/*": "./src/layouts/*",
    "#lib/*": "./src/lib/*",
    "#i18n/*": "./src/i18n/*",
    "#styles/*": "./src/styles/*"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint src astro.config.mjs",
    "format": "oxfmt --check src/lib src/i18n src/content.config.ts astro.config.mjs",
    "format:fix": "oxfmt src/lib src/i18n src/content.config.ts astro.config.mjs",
    "typecheck": "astro check",
    "check": "pnpm run lint && pnpm run format && pnpm run typecheck"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/vollkorn-sc": "5.2.8",
    "astro": "7.0.3",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@tailwindcss/vite": "4.3.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "vite": "8.1.0"
  }
}
