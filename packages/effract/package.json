{
  "name": "@tmonier/effract",
  "version": "0.4.0",
  "description": "React components written as Effect programs. yield* services and React hooks in one render pass; run the same component anywhere.",
  "keywords": [
    "effect",
    "fiber",
    "react",
    "react-server-components",
    "reactivity",
    "rsc",
    "signals",
    "ssr"
  ],
  "homepage": "https://effract.tmonier.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/get-tmonier/effract.git",
    "directory": "packages/effract"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#domain/*": "./src/domain/*",
    "#application/*": "./src/application/*",
    "#infrastructure/*": "./src/infrastructure/*"
  },
  "exports": {
    ".": {
      "react-server": {
        "types": "./src/index.server.ts",
        "default": "./src/index.server.ts"
      },
      "default": {
        "types": "./src/index.client.ts",
        "default": "./src/index.client.ts"
      }
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "react-server": {
          "types": "./dist/index.server.d.mts",
          "import": "./dist/index.server.mjs"
        },
        "default": {
          "types": "./dist/index.client.d.mts",
          "import": "./dist/index.client.mjs"
        }
      }
    },
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "effect": "catalog:",
    "happy-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": ">=4.0.0-beta.88 <5.0.0",
    "react": "^19.0.0"
  }
}
